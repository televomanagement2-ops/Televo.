# =============================================================================
# Televo — variabili d'ambiente (TEMPLATE)
# Copia questo file in `.env` e riempi i valori reali. NON committare `.env`.
# =============================================================================

# --- Supabase (progetto hosted, regione EU) ---
# Dashboard: Project Settings > API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...                 # chiave pubblica (client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # SOLO server/Edge Functions. MAI nel client.
SUPABASE_DB_PASSWORD=                    # password DB (per supabase link / db push)

# --- LiveKit Cloud (free tier) ---
# Dashboard LiveKit: Settings > Keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=wss://YOUR-project.livekit.cloud

# --- Perspective API (Google Cloud) — moderazione testo ---
PERSPECTIVE_API_KEY=

# --- PostHog — analytics (GDPR, free tier) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# --- Segreto per invocare le funzioni cron (header x-cron-secret) ---
# NB: per le notifiche push, il cron (dispatch_push) legge URL/chiavi da Vault,
# non da qui. Vedi README → "Segreti per le notifiche push (Vault)".
CRON_SECRET=

# --- Stripe (RIMANDATO al 2027 — lascia vuoto per ora) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
