# Televo mobile — variabili pubbliche (esposte al client via app.json/extra).
# NON mettere qui chiavi segrete: anon key e URL sono pubbliche per design (RLS
# protegge i dati). Service role key, segreti LiveKit/Stripe vivono SOLO nel
# backend (Supabase secrets / Vault), MAI nel client.

EXPO_PUBLIC_SUPABASE_URL=https://mmunnybytyfybncohkky.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# URL WebSocket pubblico di LiveKit Cloud (il token però è firmato server-side).
EXPO_PUBLIC_LIVEKIT_WS_URL=wss://YOUR-project.livekit.cloud

# Google Sign-In (nativo). Crea gli OAuth client su Google Cloud:
#  - Web client id  -> serve sia a GoogleSignin (idToken) sia al provider Google su Supabase.
#  - iOS client id  -> usato dal config plugin (iosUrlScheme = reverse del client id iOS).
# Mettili anche in app.json -> extra.googleWebClientId / googleIosClientId.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
